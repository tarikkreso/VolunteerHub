# Environment variables for local development
# Copy this file to .env and fill in the values

# Database
DB_NAME=220193
DB_HOST=sqlserver
DB_INTERNAL_PORT=1433
DB_USER=sa
DB_PASSWORD=<set-a-strong-local-password>
DB_TRUST_SERVER_CERTIFICATE=True
SQL_HOST_PORT=1433
MSSQL_PID=Developer
SQLSERVER_CONTAINER_NAME=volunteerhub-sqlserver

# Runtime
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:80
DOTNET_ENVIRONMENT=Production
API_HOST_PORT=7000
API_CONTAINER_NAME=volunteerhub-api
WORKER_CONTAINER_NAME=volunteerhub-worker
AUTH_PASSWORD_RESET_EXPIRATION_MINUTES=30
APP_USE_HTTPS_REDIRECTION=false
DESKTOP_CLIENT_URL=http://localhost:7000
MOBILE_CLIENT_URL=http://localhost:5000
API_CLIENT_URL=http://127.0.0.1:7000

# JWT
JWT_KEY=<set-at-least-32-random-characters>
JWT_ISSUER=VolunteerHub
JWT_AUDIENCE=VolunteerHub

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_INTERNAL_PORT=5672
RABBITMQ_HOST_PORT=5672
RABBITMQ_MANAGEMENT_HOST_PORT=15672
RABBITMQ_USER=<set-rabbitmq-user>
RABBITMQ_PASSWORD=<set-rabbitmq-password>
RABBITMQ_CONTAINER_NAME=volunteerhub-rabbitmq

# Stripe (for donations)
STRIPE_SECRET_KEY=<set-stripe-secret-key>
STRIPE_PUBLISHABLE_KEY=<set-stripe-publishable-key>
STRIPE_WEBHOOK_SECRET=<set-stripe-webhook-secret>

# SMTP (for email notifications)
SMTP_HOST=<set-smtp-host-or-mailhog>
SMTP_PORT=587
SMTP_USERNAME=<set-smtp-username>
SMTP_PASSWORD=<set-smtp-password>
SMTP_USE_SSL=true
SMTP_FROM_EMAIL=<set-from-email>
SMTP_FROM_NAME=VolunteerHub

# MailHog host ports (Docker)
MAILHOG_SMTP_HOST_PORT=1025
MAILHOG_WEB_HOST_PORT=8025
MAILHOG_CONTAINER_NAME=volunteerhub-mailhog
